<Window x:Class="ProductDossier.RoleManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление ролями"
        Width="620"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#EDF2FB"
        FontSize="18">

    <Window.Resources>
        <!-- Вторичная кнопка в стилистике PdFilterActionButton -->
        <Style x:Key="PdSecondaryActionButton"
           TargetType="Button"
           BasedOn="{StaticResource PdFilterActionButton}">
            <Setter Property="Background" Value="#E9F0FF"/>
            <Setter Property="BorderBrush" Value="#9FB9E8"/>
            <Setter Property="Foreground" Value="{StaticResource PdText}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0063D3"/>
                    <Setter Property="BorderBrush" Value="#005BC1"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            Background="#D7E5FF"
            Margin="16"
            Padding="14">

        <Border CornerRadius="14"
                Background="White"
                BorderBrush="#9FB9E8"
                BorderThickness="1.5"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>

                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Управление ролями"
                           FontSize="22"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="{StaticResource PdText}"/>

                <!-- Логин -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Логин пользователя"
                               Foreground="{StaticResource PdText}"/>

                    <Border Grid.Row="2" Style="{StaticResource PdFieldBorderThin}">
                        <TextBox x:Name="tbLogin"
                                 Style="{StaticResource PdTextBoxThin}"
                                 Width="Auto"
                                 HorizontalAlignment="Stretch"
                                 MaxLength="60"
                                 LostFocus="tbLogin_LostFocus"/>
                    </Border>
                </Grid>

                <!-- Роль -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Роль"
                               Foreground="{StaticResource PdText}"/>

                    <Border Grid.Row="2" Style="{StaticResource PdFieldBorderThin}">
                        <ComboBox x:Name="cbRole"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Height="26"
                                  FontSize="18"/>
                    </Border>
                </Grid>

                <!-- Текущая роль -->
                <TextBlock Grid.Row="6"
                           x:Name="tbCurrentRoleInfo"
                           Foreground="{StaticResource PdText}"
                           Text=""/>

                <!-- Кнопки -->
                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Style="{StaticResource PdSecondaryActionButton}"
                            Width="140"
                            Content="Отмена"
                            Click="btnCancel_Click"/>

                    <Button Grid.Column="3"
                            Style="{StaticResource PdFilterActionButton}"
                            Width="160"
                            Content="Выдать роль"
                            Click="btnApply_Click"/>
                </Grid>
            </Grid>

        </Border>
    </Border>
</Window>