<Window x:Class="ProductDossier.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История"
        Width="1140"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#EDF2FB"
        FontSize="18">

    <Window.Resources>
        <Style x:Key="HistoryCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <Style x:Key="HistoryCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#D4DEEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HistoryRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Height" Value="Auto"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F7FAFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            Background="#D7E5FF"
            Margin="16"
            Padding="14">

        <Border CornerRadius="14"
                Background="White"
                BorderBrush="#9FB9E8"
                BorderThickness="1.5"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="История изменений"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PdText}"
                               HorizontalAlignment="Center"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Фамилия/имя/отчество"
                                       Foreground="{StaticResource PdText}"
                                       Margin="2,0,0,6"/>
                            <Border Style="{StaticResource PdFieldBorderThin}">
                                <TextBox x:Name="tbFio"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         TextChanged="Filters_Changed"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Операция"
                                       Foreground="{StaticResource PdText}"
                                       Margin="2,0,0,6"/>
                            <Border Style="{StaticResource PdFieldBorderThin}">
                                <ComboBox x:Name="cbOperation"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Height="26"
                                          FontSize="18"
                                          SelectionChanged="Filters_Changed"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Изделие (номер/название)"
                                       Foreground="{StaticResource PdText}"
                                       Margin="2,0,0,6"/>
                            <Border Style="{StaticResource PdFieldBorderThin}">
                                <TextBox x:Name="tbProduct"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         TextChanged="Filters_Changed"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Документ (номер/название)"
                                       Foreground="{StaticResource PdText}"
                                       Margin="2,0,0,6"/>
                            <Border Style="{StaticResource PdFieldBorderThin}">
                                <TextBox x:Name="tbDocument"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         TextChanged="Filters_Changed"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2">
                    <DataGrid x:Name="dgHistory"
                              ItemsSource="{Binding Rows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              Margin="0"
                              AlternationCount="2"
                              CellStyle="{StaticResource HistoryCellStyle}"
                              RowStyle="{StaticResource HistoryRowStyle}"
                              ColumnWidth="SizeToHeader"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              HorizontalGridLinesBrush="#D4DEEE"
                              VerticalGridLinesBrush="#D4DEEE"
                              GridLinesVisibility="None"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата"
                                                Binding="{Binding ChangedAtLocal}"
                                                Width="SizeToCells"
                                                MinWidth="150"
                                                ElementStyle="{StaticResource HistoryCellTextStyle}"/>

                            <DataGridTextColumn Header="Пользователь"
                                                Binding="{Binding UserFullName}"
                                                Width="SizeToCells"
                                                MinWidth="220"
                                                ElementStyle="{StaticResource HistoryCellTextStyle}"/>

                            <DataGridTextColumn Header="Операция"
                                                Binding="{Binding OperationDisplay}"
                                                Width="SizeToCells"
                                                MinWidth="170"
                                                ElementStyle="{StaticResource HistoryCellTextStyle}"/>

                            <DataGridTextColumn Header="Изделие"
                                                Binding="{Binding ProductDisplay}"
                                                Width="SizeToCells"
                                                MinWidth="200"
                                                ElementStyle="{StaticResource HistoryCellTextStyle}"/>

                            <DataGridTextColumn Header="Документ"
                                                Binding="{Binding DocumentDisplay}"
                                                Width="SizeToCells"
                                                MinWidth="200"
                                                ElementStyle="{StaticResource HistoryCellTextStyle}"/>

                            <DataGridTextColumn Header="Файл"
                                                Binding="{Binding FileName}"
                                                Width="SizeToCells"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource HistoryCellTextStyle}"/>

                            <DataGridTextColumn Header="Путь"
                                                Binding="{Binding FilePath}"
                                                Width="SizeToCells"
                                                MinWidth="240"
                                                ElementStyle="{StaticResource HistoryCellTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="Ничего не найдено"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#6B7A99"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=dgHistory, Path=HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>