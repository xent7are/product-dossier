<Window x:Class="ProductDossier.AddFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Добавление документа"
        Width="620"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EDF2FB"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDrop="Window_PreviewDrop"
        DragLeave="Window_DragLeave">

    <Window.Resources>

        <!-- Вторичная кнопка в стилистике PdFilterActionButton -->
        <Style x:Key="PdSecondaryActionButton"
           TargetType="Button"
           BasedOn="{StaticResource PdFilterActionButton}">
            <Setter Property="Background" Value="#E9F0FF"/>
            <Setter Property="BorderBrush" Value="#9FB9E8"/>
            <Setter Property="Foreground" Value="{StaticResource PdText}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0063D3"/>
                    <Setter Property="BorderBrush" Value="#005BC1"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- Внешняя карточка -->
    <Border CornerRadius="18"
            Background="#D7E5FF"
            Margin="16"
            Padding="14">

        <!-- Внутренняя карточка -->
        <Border CornerRadius="14"
                Background="White"
                BorderBrush="#9FB9E8"
                BorderThickness="1.5"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>

                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock Text="Добавление документа"
                           FontSize="22"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="{StaticResource PdText}"/>

                <!-- Номер документа -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Номер документа"
                               Foreground="{StaticResource PdText}"/>

                    <Border Grid.Row="2" Style="{StaticResource PdFieldBorderThin}">
                        <TextBox x:Name="tbDocNumber"
                                 Style="{StaticResource PdTextBoxThin}"
                                 Width="Auto"
                                 HorizontalAlignment="Stretch"
                                 MaxLength="80"/>
                    </Border>
                </Grid>

                <!-- Название документа -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Название документа"
                               Foreground="{StaticResource PdText}"/>

                    <Border Grid.Row="2" Style="{StaticResource PdFieldBorderThin}">
                        <TextBox x:Name="tbDocName"
                                 Style="{StaticResource PdTextBoxThin}"
                                 Width="Auto"
                                 HorizontalAlignment="Stretch"
                                 MaxLength="120"/>
                    </Border>
                </Grid>

                <!-- Статус -->
                <Grid Grid.Row="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Статус документа"
                               Foreground="{StaticResource PdText}"/>

                    <Border Grid.Row="2" Style="{StaticResource PdFieldBorderThin}">
                        <ComboBox x:Name="cbStatus"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Height="26"
                                  FontSize="16"/>
                    </Border>
                </Grid>

                <!-- Выбранный файл -->
                <Grid Grid.Row="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                       Text="Выбранный файл (имя и расширение)"
                       Foreground="{StaticResource PdText}"/>

                    <Border x:Name="bdDropZone"
                        Grid.Row="2"
                        Style="{StaticResource PdFieldBorderThin}"
                        Background="#EDF2FB">
                                    <TextBox x:Name="tbSelectedFile"
                             Style="{StaticResource PdTextBoxThin}"
                             Width="Auto"
                             HorizontalAlignment="Stretch"
                             IsReadOnly="True"
                             Text="Нажмите «Выбрать файл» или перетащите файл сюда"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             Background="Transparent"/>
                    </Border>
                </Grid>

                <!-- Кнопки -->
                <Grid Grid.Row="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Style="{StaticResource PdSecondaryActionButton}"
                            Width="160"
                            Content="Выбрать файл"
                            Click="btnPick_Click"/>

                    <Button Grid.Column="3"
                            Style="{StaticResource PdSecondaryActionButton}"
                            Width="140"
                            Content="Отмена"
                            Click="btnCancel_Click"/>

                    <Button Grid.Column="5"
                            Style="{StaticResource PdFilterActionButton}"
                            Width="160"
                            Content="Сохранить"
                            x:Name="btnAdd"
                            IsEnabled="False"
                            Click="btnAdd_Click"/>
                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>
