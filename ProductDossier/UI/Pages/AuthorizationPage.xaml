<Page x:Class="ProductDossier.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ProductDossier"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1140"
      Title="Авторизация">

    <Grid Background="#edf2fb">
        <!-- Разметка страницы -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- Заголовок страницы -->
        <TextBlock Grid.Row="0" Grid.Column="1" Text="Авторизация"
                   FontSize="36" FontWeight="Bold" FontFamily="NunitoBold" Foreground="#177EF3"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Область ввода данных: рамка как в модальных окнах -->
        <Border Grid.Column="1" Grid.Row="1"
                CornerRadius="18"
                Background="#D7E5FF"
                Padding="14">

            <Border CornerRadius="14"
                    Background="White"
                    BorderBrush="#9FB9E8"
                    BorderThickness="1.5"
                    Padding="18">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Поле с вводом логина -->
                    <TextBlock Margin="25,0,0,0" Text="Введите логин"/>
                    <Border Style="{StaticResource PdFieldBorderThin}" Margin="12">
                        <TextBox Name="loginTextBlock"
                                 Style="{StaticResource PdTextBoxThin}"
                                 MaxLength="20"
                                 PreviewKeyDown="TextBox_PreviewKeyDown"
                                 PreviewTextInput="TextBox_PreviewTextInput"/>
                    </Border>

                    <!-- Поле с вводом пароля -->
                    <TextBlock Margin="25,0,0,0" Text="Введите пароль"/>
                    <Border Style="{StaticResource PdFieldBorderThin}" Margin="12">
                        <PasswordBox Name="passwordTextBlock"
                                     Style="{StaticResource PdPasswordBoxThin}"
                                     MaxLength="20"
                                     PreviewKeyDown="PasswordBox_PreviewKeyDown"
                                     PreviewTextInput="PasswordBox_PreviewTextInput"/>
                    </Border>

                    <TextBlock Text="Нет учетной записи?" FontSize="14" Margin="30, 10, 0, -10"/>

                    <!-- Кнопки "Регистрация" и "Войти" -->
                    <StackPanel Orientation="Horizontal">
                        <Button Name="buttonRegistration" Content="Регистрация"
                                HorizontalAlignment="Center" Click="buttonRegistration_Click" />
                        <Button Name="buttonLogIn" Content="Войти"
                                HorizontalAlignment="Center" Click="buttonLogIn_Click" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>